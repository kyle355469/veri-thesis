{
  "requirements": {
    "functionality": [
      "Top‑level controller that connects the SDC Core to a Wishbone bus.",
      "Provides a Wishbone slave interface for configuration/control.",
      "Provides a Wishbone master interface for data transfer to/from the bus.",
      "Handles clock‑domain crossing between the SDC Core clock domain and the system bus clock domain.",
      "Implements optional SD_CLK_SEP logic to generate a separate SD clock when enabled.",
      "Implements optional SDC_IRQ_ENABLE logic to gate interrupt generation.",
      "Supports reset synchronization across clock domains.",
      "Exposes status and error signals to the bus."
    ],
    "performance": [
      "Maximum bus transaction latency: ≤ 5 WB cycles.",
      "CDC FIFO depth: ≥ 64 words to accommodate burst transfers.",
      "SD_CLK_SEP generation must not exceed 10 % jitter relative to core clock."
    ],
    "I/O interface": {
      "wb_slave": {
        "address_width": 32,
        "data_width": 32,
        "sel_width": 4,
        "clock": "wb_clk_i",
        "reset": "wb_rst_i"
      },
      "wb_master": {
        "address_width": 32,
        "data_width": 32,
        "sel_width": 4,
        "clock": "wb_clk_i",
        "reset": "wb_rst_i"
      },
      "core_clk": "sdc_clk_i",
      "core_reset": "sdc_rst_i",
      "sd_clk_sep": "sd_clk_o",
      "irq_enable": "irq_en_i",
      "irq_out": "irq_o"
    },
    "PPA constraints": {
      "area": "≤ 5 kGE (generic logic elements)",
      "power": "≤ 50 mW at 100 MHz system clock",
      "timing": "All paths must meet 100 MHz clock period (10 ns)."
    }
  },
  "modules": [
    {
      "name": "sdc_controller",
      "needs_decomposition": true,
      "sub_spec": {
        "description": "Top‑level module that wires all sub‑blocks together.",
        "submodules": [
          "wb_slave_if",
          "wb_master_if",
          "cdc_fifo",
          "clk_sync",
          "sd_clk_sep_logic",
          "irq_enable_logic",
          "sdc_core_wrapper"
        ]
      }
    },
    {
      "name": "wb_slave_if",
      "needs_decomposition": false,
      "description": "Wishbone slave interface IP."
    },
    {
      "name": "wb_master_if",
      "needs_decomposition": false,
      "description": "Wishbone master interface IP."
    },
    {
      "name": "cdc_fifo",
      "needs_decomposition": false,
      "description": "Dual‑clock FIFO for data transfer from core to bus."
    },
    {
      "name": "clk_sync",
      "needs_decomposition": false,
      "description": "Two‑flip‑flop synchronizer for reset and control signals."
    },
    {
      "name": "sd_clk_sep_logic",
      "needs_decomposition": false,
      "description": "Optional logic to generate a separate SD clock."
    },
    {
      "name": "irq_enable_logic",
      "needs_decomposition": false,
      "description": "Optional logic to gate interrupt generation."
    },
    {
      "name": "sdc_core_wrapper",
      "needs_decomposition": false,
      "description": "Wrapper around the SDC Core that exposes data_in/out and control signals."
    }
  ],
